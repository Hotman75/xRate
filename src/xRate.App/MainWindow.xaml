<Window x:Class="xRate.App.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" Title="xRate">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid RequestedTheme="Dark" Background="#1C1C1C">
        <Grid.RowDefinitions>
            <RowDefinition Height="45" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="10"
                HorizontalAlignment="Left">
                <Image Source="Assets/icon.png" Width="18" Height="18" />
                <TextBlock Text="xRate" FontSize="12" Foreground="Gray" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Padding="20">

            <StackPanel Width="380" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,15,0,0" Spacing="20">

                <TextBlock Text="xRate" FontSize="32" FontFamily="{StaticResource UbuntuMedium}" FontWeight="Medium"
                    CharacterSpacing="-30" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFFFFF" Offset="0.3" />
                            <GradientStop Color="#EBEBEB" Offset="1.0" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <Grid RowDefinitions="Auto, Auto">
                    <TextBlock Grid.Row="0" Text="Amount" FontSize="14" Foreground="LightGray" Margin="5,0,0,5" />
                    <TextBox Grid.Row="1" x:Name="AmountTextBox" PlaceholderText="Enter amount..."
                        HorizontalAlignment="Stretch" KeyDown="AmountTextBox_KeyDown" />
                </Grid>

                <StackPanel Spacing="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="From" FontSize="14" Foreground="LightGray"
                            Margin="5,0,0,5" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="To" FontSize="14" Foreground="LightGray"
                            Margin="5,0,0,5" />

                        <ComboBox Grid.Row="1" Grid.Column="0" x:Name="FromComboBox" HorizontalAlignment="Stretch"
                            SelectionChanged="OnCurrencySelectionChanged" />

                        <Button Grid.Row="1" Grid.Column="1" x:Name="SwapButton" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                            Click="SwapButton_Click">
                            <SymbolIcon Symbol="Sync" Foreground="#0078D4" />
                        </Button>

                        <ComboBox Grid.Row="1" Grid.Column="2" x:Name="ToComboBox" HorizontalAlignment="Stretch"
                            SelectionChanged="OnCurrencySelectionChanged" />
                    </Grid>

                    <Button x:Name="SetDefaultButton" Content="Set as default" Click="SetDefaultButton_Click"
                        Background="Transparent" BorderThickness="0" Foreground="Gray" FontSize="12"
                        HorizontalAlignment="Center" Visibility="Collapsed" />
                </StackPanel>

                <Button x:Name="ConvertButton" Content="Convert" Click="ConvertButton_Click"
                    HorizontalAlignment="Stretch" Height="48" FontSize="16" FontWeight="Bold" Foreground="White"
                    BorderThickness="0" CornerRadius="8" Margin="0,10,0,0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#004578" Offset="0.0" />
                            <GradientStop Color="#0078D4" Offset="0.5" />
                            <GradientStop Color="#2B88D8" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Border x:Name="ResultBorder" Visibility="Visible" Opacity="1.0" MinHeight="80" Background="#15FFFFFF"
                    CornerRadius="12" Padding="20">
                    <Grid ColumnDefinitions="*, Auto">

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="ResultTextBlock" FontSize="17" FontWeight="Medium" TextAlignment="Center"
                                Foreground="#7FDBFF" TextWrapping="Wrap" Text="Ready to convert" />

                            <TextBlock x:Name="RateTextBlock" FontSize="12" Foreground="Gray" TextAlignment="Center"
                                Margin="0,4,0,0" Visibility="Collapsed" />

                            <TextBlock x:Name="OfflineWarningTextBlock" FontSize="11" Foreground="#FFA500"
                                TextAlignment="Center" Margin="0,4,0,0" Visibility="Collapsed" />
                        </StackPanel>

                        <Button x:Name="CopyButton" Grid.Column="1" Background="Transparent" BorderThickness="0"
                            Margin="10,0,0,0" Click="CopyButton_Click" VerticalAlignment="Center">
                            <SymbolIcon Symbol="Copy" Foreground="Gray" />
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>