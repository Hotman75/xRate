<Window x:Class="xRate.App.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" Title="xRate">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid RequestedTheme="Dark" Background="#1C1C1C">
        <Grid.RowDefinitions>
            <RowDefinition Height="45" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="10">
                <Image Source="Assets/icon.png" Width="18" Height="18" />
                <TextBlock Text="xRate" FontSize="12" Foreground="Gray" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Padding="30,10,30,30">
                <StackPanel MaxWidth="380" HorizontalAlignment="Stretch" VerticalAlignment="Top" Spacing="12">

                    <TextBlock Text="xRate" FontSize="28" FontFamily="{StaticResource UbuntuMedium}" FontWeight="Medium"
                        CharacterSpacing="-30" HorizontalAlignment="Center" Margin="0,0,0,5">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFFFFF" Offset="0.3" />
                                <GradientStop Color="#A0A0A0" Offset="1.0" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="AmountTextBox" Grid.Column="0" FontSize="16" FontWeight="SemiBold"
                            TextAlignment="Left" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#22FFFFFF"
                            Padding="10,8,0,8" PlaceholderText="" TextChanged="AmountTextBox_TextChanged"
                            GotFocus="AmountTextBox_GotFocus" />

                        <TextBlock x:Name="InputCurrencySymbol" Grid.Column="1" FontSize="16" FontWeight="SemiBold"
                            Foreground="#808080" VerticalAlignment="Center" Margin="10,0,5,0" />
                    </Grid>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="FromComboBox" Grid.Column="0" HorizontalAlignment="Stretch" FontSize="14"
                            SelectionChanged="OnCurrencySelectionChanged" />

                        <Button x:Name="SwapButton" Grid.Column="1" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                            Click="SwapButton_Click">
                            <SymbolIcon Symbol="Sync" Foreground="#0078D4" />
                        </Button>

                        <ComboBox x:Name="ToComboBox" Grid.Column="2" HorizontalAlignment="Stretch" FontSize="14"
                            SelectionChanged="OnCurrencySelectionChanged" />
                    </Grid>

                    <Button x:Name="SetDefaultButton" Content="Set as default Currencies" Click="SetDefaultButton_Click"
                        Background="Transparent" BorderThickness="0" Foreground="Gray" FontSize="12"
                        HorizontalAlignment="Center" Visibility="Collapsed" />

                    <Border x:Name="ResultBorder" Visibility="Visible" Background="#15FFFFFF" CornerRadius="10"
                        Padding="15" Margin="0,5,0,0" MinHeight="56">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock x:Name="ResultTextBlock" Grid.Column="0" FontSize="16" FontWeight="SemiBold"
                                VerticalAlignment="Center" Foreground="#0078D4" TextWrapping="Wrap" />

                            <Button x:Name="CopyResultButton" Grid.Column="1" Background="Transparent"
                                BorderThickness="0" Margin="10,0,0,0" Click="CopyResultButton_Click"
                                VerticalAlignment="Center" Visibility="Collapsed">
                                <SymbolIcon Symbol="Copy" Foreground="Gray" />
                            </Button>
                        </Grid>
                    </Border>

                    <Border x:Name="RateBorder" Visibility="Visible" Background="#0AFFFFFF" CornerRadius="8"
                        Padding="15,10" BorderBrush="#15FFFFFF" BorderThickness="1">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock x:Name="RateTextBlock" Grid.Column="0" FontSize="14" Foreground="#EBEBEB"
                                FontWeight="Medium" VerticalAlignment="Center" />

                            <Button x:Name="CopyRateButton" Grid.Column="1" Background="Transparent" BorderThickness="0"
                                Click="CopyRateButton_Click" VerticalAlignment="Center" Visibility="Collapsed">
                                <SymbolIcon Symbol="Copy" Foreground="Gray" />
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>